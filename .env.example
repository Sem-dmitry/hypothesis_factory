# Copy to .env and fill in. .env itself is gitignored.
# Bash:   set -a; . ./.env; set +a
# Windows PowerShell examples are in README.md.

# --- RouterAI: chat, vision, embeddings, web search -------------------------
# RouterAI uses an OpenAI-compatible protocol for all model calls.
ROUTER_AI_API_KEY=your-routerai-key
ROUTER_AI_BASE_URL=https://routerai.ai/api/v1

# Optional RouterAI attribution headers.
# ROUTER_AI_APP_URL=https://your-app.example
# ROUTER_AI_APP_TITLE=Фабрика гипотез

# Default chat model when a spec is not given.
# COSCIENTIST_DEFAULT_MODEL=claude-sonnet-4-20250514

# Vision model for parsing images, schemes, regulations and equipment lists.
# COSCIENTIST_VISION_MODEL=google/gemini-2.5-pro

# Optional friendly-name -> provider-id remap (JSON).
# ROUTER_AI_MODEL_MAP={"o3":"openai/o3","gemini-2.5-pro":"google/gemini-2.5-pro"}

# Embeddings also go through RouterAI's OpenAI-compatible endpoint.
# If unset, the system reuses ROUTER_AI_API_KEY and ROUTER_AI_BASE_URL.
ROUTER_AI_EMBEDDING_MODEL=text-embedding-3-small
ROUTER_AI_EMBEDDING_DIMENSIONS=256
# ROUTER_AI_EMBEDDING_API_KEY=your-routerai-embedding-key
# ROUTER_AI_EMBEDDING_BASE_URL=https://routerai.ai/api/v1

# --- Storage ----------------------------------------------------------------
# Where corpus index + run state are written (default: ~/.coscientist):
# COSCIENTIST_DIR=~/.coscientist

# --- Web research -----------------------------------------------------------
# Deep-mode web research uses RouterAI web-search and reuses ROUTER_AI_API_KEY.
# Optional override of the web-search model:
# COSCIENTIST_WEBSEARCH_MODEL=google/gemini-2.5-flash
